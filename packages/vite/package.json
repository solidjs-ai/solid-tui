{
  "name": "@solid-tui/vite",
  "version": "0.1.1",
  "description": "Vite plugin for solid-tui: universal Solid TSX, in-process terminal dev server, and Node builds.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-ai/solid-tui.git",
    "directory": "packages/vite"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test --passWithNoTests",
    "check:type": "tsc --noEmit",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "vite-plugin-solid": "catalog:"
  },
  "devDependencies": {
    "@solid-tui/runtime": "workspace:*",
    "@types/node": "catalog:",
    "solid-js": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@solid-tui/runtime": "workspace:^",
    "solid-js": "^1.9.0",
    "vite": "^8"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}

{
  "name": "@solid-tui/components",
  "version": "0.1.1",
  "description": "High-level Solid components for solid-tui, composed from @solid-tui/runtime primitives.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-ai/solid-tui.git",
    "directory": "packages/components"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test --passWithNoTests",
    "check:type": "tsc --noEmit",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@solid-tui/runtime": "workspace:*",
    "@solid-tui/testing": "workspace:*",
    "@types/node": "catalog:",
    "chalk": "catalog:",
    "string-width": "catalog:",
    "strip-ansi": "catalog:",
    "typescript": "catalog:",
    "vite-plugin-solid": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@solid-tui/runtime": "workspace:^",
    "solid-js": "^1.9.0"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}

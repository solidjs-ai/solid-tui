    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "catalog:",
    "ansi-escapes": "catalog:",
    "better-yoga-layout": "^0.2.2",
    "chalk": "catalog:",
    "cli-boxes": "^3.0.0",
    "cli-truncate": "^6.0.0",
    "code-excerpt": "^4.0.0",
    "is-in-ci": "catalog:",
    "patch-console": "catalog:",
    "signal-exit": "^4.1.0",
    "slice-ansi": "^9.0.0",
    "solid-js": "catalog:",
    "stack-utils": "^2.0.6",
    "string-width": "catalog:",
    "terminal-size": "catalog:",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/stack-utils": "^2.0.3",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },

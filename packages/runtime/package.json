{
  "name": "@solid-tui/runtime",
  "version": "0.1.1",
  "description": "Solid terminal renderer with better-yoga-layout flexbox layout.",
  "keywords": [
    "ansi",
    "cli",
    "console",
    "flexbox",
    "ink",
    "renderer",
    "solid",
    "terminal",
    "tui",
    "yoga"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-ai/solid-tui.git",
    "directory": "packages/runtime"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./internal": "./dist/internal.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test --passWithNoTests",
